# ARM Docker — plantilla de configuración para scripts de integración
# Copiar a .env.arm y completar con valores reales.

ARM_SSH_ALIAS=arm
ARM_PHP_CONTAINER=infra-php-1
ARM_MARIADB_CONTAINER=infra-mariadb-1
ARM_REDIS_CONTAINER=infra-redis-1
ARM_WP_PATH=/var/www/html
ARM_HOST_PLUGIN_PATH=/srv/pinkmask/wp-content/plugins/woo2odoo

ARM_DB_USER=
ARM_DB_PASS=
ARM_DB_NAME=pinkmask_wp
ARM_REDIS_PASS=

ARM_PRIVATE_IP=10.0.0.234
